rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ─────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn()
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // ── Users ────────────────────────────────────────────────────────────────
    // User profile documents — readable/writable only by that user.
    // The `role` field is immutable from the client: users cannot promote
    // themselves.  Admins change roles exclusively via Cloud Functions
    // (Admin SDK), which bypasses these rules.
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId)
                   && (!("role" in request.resource.data)
                       || request.resource.data.role == resource.data.role);

      // Tokens subcollection — stores OAuth access/refresh tokens.
      // Managed exclusively by Cloud Functions (Admin SDK).
      // Raw tokens must never be exposed to the client — treat like apiKeys.
      match /tokens/{tokenDoc} {
        allow read, write: if false;
      }

      // API Keys subcollection — stores per-user AI provider keys.
      // Managed exclusively by Cloud Functions (Admin SDK).
      // Clients never read or write these directly; only masked versions are exposed.
      match /apiKeys/{provider} {
        allow read, write: if false;
      }
    }

    // ── Tasks ────────────────────────────────────────────────────────────────
    // A task belongs to the user identified by task.ownerId.
    match /tasks/{taskId} {
      allow read, update, delete: if isSignedIn()
                                  && resource.data.ownerId == request.auth.uid;

      allow create: if isSignedIn()
                    && request.resource.data.ownerId == request.auth.uid;
    }

    // ── Proposals ────────────────────────────────────────────────────────────
    // Task proposals extracted from meeting transcripts.
    //
    // READ: the assignee can always read their own proposals. Any user whose
    //       email appears in processedTranscripts/{meetingId}.attendeeEmails
    //       can also read all proposals for that meeting (read-only view).
    // UPDATE: only the current assignee (including after reassignment) can write.
    // Cloud Functions (Admin SDK) handle creation.
    match /proposals/{meetingId}/tasks/{taskId} {
      allow read: if isSignedIn() && (
        resource.data.assigneeUid == request.auth.uid ||
        (request.auth.token.email != null &&
         request.auth.token.email in
           get(/databases/$(database)/documents/processedTranscripts/$(meetingId)).data.attendeeEmails)
      );
      allow update: if isSignedIn()
                    && resource.data.assigneeUid == request.auth.uid;
    }

    // ── Proposal collection group query support ───────────────────────────────
    // The approval dashboard uses a collectionGroup("tasks") query filtered by
    // assigneeUid. Firestore requires a recursive-wildcard rule to authorise
    // collection group queries — path-specific rules alone are not sufficient.
    // This covers the dashboard and Kanban board (own tasks only).
    match /{path=**}/tasks/{taskId} {
      allow read, update: if isSignedIn()
                          && resource.data.assigneeUid == request.auth.uid;
    }

    // ── Config (org defaults) ────────────────────────────────────────────────
    // Organisation-wide defaults stored at config/orgDefaults.
    // Any signed-in user can read (so the settings page can show effective defaults).
    // Only admins (users/{uid}.role == "admin") may write.
    match /config/orgDefaults {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Config (secrets) ─────────────────────────────────────────────────────
    // KMS-encrypted credentials stored at config/secrets.
    // Only admins may read or write — primary security boundary is the API
    // layer (requireAdmin middleware), but Firestore rules are the backstop.
    match /config/secrets {
      allow read, write: if isAdmin();
    }

    // ── Config (setup) ────────────────────────────────────────────────────────
    // Onboarding setup wizard completion state. Admin-only write; admins read.
    match /config/setup {
      allow read, write: if isAdmin();
    }

    // ── Activity Log ──────────────────────────────────────────────────────────
    // Server-side only (Cloud Functions via Admin SDK). No client access needed
    // since the admin panel reads it exclusively via the /api/admin/activity endpoint.
    match /activityLog/{entry} {
      allow read, write: if false;
    }

    // ── Invites ───────────────────────────────────────────────────────────────
    // Created by admin API, consumed on first sign-in. No direct client access.
    match /invites/{email} {
      allow read, write: if false;
    }

    // ── Approval Tokens ───────────────────────────────────────────────────────
    // Single-use tokens embedded in notification email links.
    // Created and validated exclusively by Cloud Functions (Admin SDK).
    // No client should ever read or write these directly.
    match /approvalTokens/{token} {
      allow read, write: if false;
    }

    // ── OAuth State Tokens ───────────────────────────────────────────────────
    // Short-lived CSRF tokens used during the OAuth handshake.
    // Created and deleted exclusively by Cloud Functions (Admin SDK).
    // No client should ever read or write these directly.
    match /oauthStates/{stateId} {
      allow read, write: if false;
    }

    // ── Deny everything else ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
